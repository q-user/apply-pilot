# Local development environment for ApplyPilot.
#
# Copy to `.env` and edit. Values referenced by docker-compose.yml
# (POSTGRES_*, REDIS_URL, DATABASE_URL) must be in sync between
# this file and the compose service definitions.

# --- PostgreSQL (used by the `postgres` service in docker-compose.yml) ---
POSTGRES_USER=apply_pilot
POSTGRES_PASSWORD=apply_pilot
POSTGRES_DB=apply_pilot
POSTGRES_PORT=5432

# --- Redis (used by the `redis` service in docker-compose.yml) ---
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# --- Application ---
# SQLAlchemy URL consumed by the API/worker/bot/scheduler processes.
# The driver `psycopg` (v3) is the recommended modern driver; add
# `psycopg[binary]>=3.1` to pyproject.toml before the API can connect.
DATABASE_URL=postgresql+psycopg://apply_pilot:apply_pilot@postgres:5432/apply_pilot

# Port the API listens on inside the container. Exposed as 8000:8000
# in docker-compose.yml.
PORT=8000
