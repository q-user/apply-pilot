# apply-pilot environment template
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
# docker-compose auto-loads .env from this directory.
# Never commit .env (it is in .gitignore).

# --- Database ---------------------------------------------------------------
# Local dev (sqlite, bind-mounted at ./data):
#   sqlite+pysqlite:////data/app.db
# Docker Postgres:
#   postgresql+psycopg://apply_pilot:apply_pilot@db:5432/apply_pilot
DATABASE_URL=sqlite+pysqlite:////data/app.db

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Telegram bot -----------------------------------------------------------
# Token from @BotFather in Telegram. Required for the Telegram bot container.
TELEGRAM_BOT_TOKEN=replace-with-telegram-token-from-botfather
# Long-poll timeout for /getUpdates, seconds (1-90). Default 30.
TELEGRAM_POLLING_TIMEOUT=30

# --- MAX bot (vk.com / max.ru) ---------------------------------------------
# 36-char token from the MAX web UI:
#   Чаты → Перейти → Расширенные настройки → Настроить
# Required for the MAX bot container to start.
MAX_BOT_TOKEN=replace-with-max-token
# Long-poll timeout for /updates, seconds (0-90). Default 30.
# Higher = less API load, slower SIGTERM response. 30 is the recommended sweet spot.
MAX_POLLING_TIMEOUT=30
